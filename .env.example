# Environment variables declared in this file are automatically made available to Prisma.
# See the documentation for more detail: https://pris.ly/d/prisma-schema#accessing-environment-variables-from-the-schema

# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, and CockroachDB.
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings

# PostgreSQL connection string (required)
DATABASE_URL="postgresql://<username>:<password>@<host>:<port>/<database>?schema=public"

# Better Auth
BETTER_AUTH_SECRET="generate-with-openssl-rand-base64-32"
BETTER_AUTH_URL="http://localhost:3000"

# Google OAuth
GOOGLE_ID="your-google-client-id"
GOOGLE_SECRET="your-google-client-secret"

# Email Service (Resend)
RESEND_API_KEY="your-resend-api-key"

# AI integrations
# Venice uses OpenAI-compatible endpoints for embeddings/document AI.
OPENAI_API_KEY="your-openai-api-key"
VENICE_API_KEY=
AI_EMBEDDINGS_PROVIDER=venice
OPENAI_BASE_URL=https://api.venice.ai/api/v1
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536
OPENAI_CHAT_MODEL=

# Prism Codex Runtime for agentic enrichment adapter
AI_AGENT_PROVIDER=prism
PRISM_CODEX_RUNTIME_URL=
PRISM_CODEX_RUNTIME_TOKEN=

# Firecrawl (contact enrichment)
FIRECRAWL_API_KEY=            # get from https://firecrawl.dev

# Invoice Parsing (Rossum)
ROSSUM_USERNAME="your-rossum-username"
ROSSUM_PASSWORD="your-rossum-password"

# MinIO Object Storage
NEXT_PUBLIC_MINIO_ENDPOINT="https://your-minio-host"
MINIO_ENDPOINT="https://your-minio-host"
MINIO_PORT="9000"
MINIO_BUCKET="your-bucket-name"
MINIO_USE_SSL="true"
MINIO_ACCESS_KEY="your-access-key"
MINIO_SECRET_KEY="your-secret-key"

# SMTP / IMAP (optional, for email client functionality)
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="your-smtp-user"
SMTP_PASSWORD="your-smtp-password"

# Internal cron job endpoints
CRON_SECRET=                    # Secret for internal cron job endpoints

# Email feature — generate with: openssl rand -hex 32
EMAIL_ENCRYPTION_KEY=your_64_hex_char_key_here

# Campaigns — Resend email sending
RESEND_WEBHOOK_SECRET=     # Resend webhook signing secret
RESEND_FROM_EMAIL=         # e.g. noreply@yourdomain.com
