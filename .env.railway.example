# Required
# Use the DATABASE_URL from your Railway Postgres/pgvector service.
# If the pgvector template requires SSL, append ?sslmode=require.
DATABASE_URL=${{Postgres.DATABASE_URL}}
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=https://your-nextcrm.up.railway.app
NEXT_PUBLIC_APP_URL=https://your-nextcrm.up.railway.app
NEXT_PUBLIC_APP_NAME=The RaidGuild Nexus
EMAIL_ENCRYPTION_KEY=
ADMIN_EMAIL=you@example.com

# Recommended for production login/email
EMAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=
EMAIL_FROM=noreply@yourdomain.com

# Resend is also supported if EMAIL_PROVIDER is not set to sendgrid.
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@yourdomain.com

# Optional OAuth
AUTH_GOOGLE_ENABLED=false
NEXT_PUBLIC_GOOGLE_AUTH_ENABLED=false
GOOGLE_ID=
GOOGLE_SECRET=

# Optional background jobs
INNGEST_ID=nextcrm
INNGEST_APP_NAME=The RaidGuild Nexus
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
INNGEST_BASE_URL=https://your-nextcrm.up.railway.app

# Optional AI/enrichment
AI_EMBEDDINGS_PROVIDER=venice
VENICE_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.venice.ai/api/v1
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536
OPENAI_CHAT_MODEL=
AI_AGENT_PROVIDER=prism
PRISM_CODEX_RUNTIME_URL=
PRISM_CODEX_RUNTIME_TOKEN=
ANTHROPIC_API_KEY=
E2B_API_KEY=
E2B_ENRICHMENT_TEMPLATE=nextcrm-enrichment

# Optional S3-compatible document storage
NEXT_PUBLIC_MINIO_ENDPOINT=
MINIO_ENDPOINT=
MINIO_PORT=443
MINIO_BUCKET=
MINIO_USE_SSL=true
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=

# Optional campaign webhooks/cron
RESEND_WEBHOOK_SECRET=
CRON_SECRET=
